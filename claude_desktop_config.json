{
  "mcpServers": {
    "spring-boot-mcp-server-sse": {
      "transport": "sse",
      "url": "http://localhost:18080/sse"
    },
    "spring-boot-mcp-server-stdio": {
      "command": "java",
      "args": [
        "-jar",
        "target/mcp-server-demo-0.0.1-SNAPSHOT.jar",
        "--spring.profiles.active=stdio"
      ],
      "env": {
        "SPRING_AI_OPENAI_API_KEY": "your-api-key"
      }
    }
  }
}
